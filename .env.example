# Microsoft Graph / OneDrive settings
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
DRIVE_ID=your-drive-id
FOLDER_BASE_PATH="root/some_folder_for_invoices"

# OCR settings
OCR_LANGS=est+eng,eng

# LLM Provider selection (ollama, cerebras, openrouter, github_models)
LLM_PROVIDER=github_models

# OLLAMA settings (when LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=deepseek-r1:7b

# Cerebras settings (when LLM_PROVIDER=cerebras)
CEREBRAS_API_KEY=your-cerebras-api-key
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# OpenRouter settings (when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=poolside/laguna-m.1:free

# GitHub Models settings (when LLM_PROVIDER=github_models)
GITHUB_MODELS_API_KEY=your-github-models-api-key
GITHUB_MODELS_MODEL=meta/Llama-3.3-70B-Instruct
GITHUB_MODELS_URL=https://models.github.ai/inference/chat/completions

# SimplBooks importer settings
SIMPLBOOKS_BASE_URL=https://www.simplbooks.ee
SIMPLBOOKS_USER=your-simplbooks-email
SIMPLBOOKS_PASSWORD=your-simplbooks-password

# SimplBooks account codes (from your chart of accounts)
SIMPLBOOKS_ACCOUNT_CODE_CAR_EXPENSE=5202
SIMPLBOOKS_ACCOUNT_CODE_EU_BUY=5204
SIMPLBOOKS_ACCOUNT_CODE_DEFAULT=5200

# SimplBooks VAT profiles (must match your configured profiles)
SIMPLBOOKS_VAT_PROFILE_CAR_EXPENSE=24% Autokulud (osaliselt ettevõtluseks kasutatav)
SIMPLBOOKS_VAT_PROFILE_EU_BUY=0% Kauba ühendusesisene soetamine
SIMPLBOOKS_VAT_PROFILE_DEFAULT=24% Eesti
